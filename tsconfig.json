{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@actions/*": ["page-objects/actions/*"],
      "@locators/*": ["page-objects/locators/*"],
      "@utils/*": ["utils/*"],
      "@components/*": ["src/components/*"],
      "@helpers/*": ["src/helpers/*"],
      "@config/*": ["src/config/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "page-objects/**/*.ts",
    "utils/**/*.ts",
    "src/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report",
    "playwright-automated-test-opencart"
  ]
}
