{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "6.0",
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@pages/*": ["pages/*"],
            "@components/*": ["pages/components/*"],
            "@fixtures/*": ["fixtures/*"],
            "@utils/*": ["utils/*"],
            "@config/*": ["config/*"],
            "@constants/*": ["constants/*"],
            "@test-data/*": ["test-data/*"]
        }
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts",
        "fixtures/**/*.ts",
        "utils/**/*.ts",
        "config/**/*.ts",
        "constants/**/*.ts",
        "scripts/**/*.ts",
        "playwright.config.ts"
    ],
    "exclude": [
        "node_modules",
        "test-results",
        "playwright-report",
        "blob-report"
    ]
}
