# ──────────────────────────────────────────────
# PetPals Test Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env.local or .env.staging
# Switch environment: TEST_ENV=local or TEST_ENV=staging (default)
#
# Usage:
#   TEST_ENV=local npx playwright test
#   TEST_ENV=staging npx playwright test
#   npx playwright test                    ← defaults to staging
# ──────────────────────────────────────────────

# Application Configuration
BASE_URL=http://localhost:3002

# Test User Credentials
TEST_USER_EMAIL=garaga@petpals.com
TEST_USER_PASSWORD=@admin123

# Environment
NODE_ENV=test

# Logging
LOG_LEVEL=debug

# TEST RAIL
TESTRAIL_BASE_URL=https://yourcompany.testrail.io
TESTRAIL_EMAIL=your@email.com
TESTRAIL_API_KEY=your-api-key
TESTRAIL_PROJECT_ID=your-project-id
